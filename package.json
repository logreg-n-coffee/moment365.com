  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
